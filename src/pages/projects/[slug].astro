---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, subtitle, description, status, statsTitle, stats, technologies } =
  project.data;
---

<Layout title={`${title} — Metaintellect`} description={description}>
  <article data-section="project" class="relative px-6 py-16 sm:px-8">
    <!-- Subtle top glow — matches main page warmth -->
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-[700px] -translate-x-1/2 rounded-full bg-accent/[0.04] blur-[120px]"
    ></div>

    <div class="relative mx-auto max-w-2xl">
      <!-- Back -->
      <a
        href="/"
        class="mb-12 inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-accent"
      >
        &larr; Back
      </a>

      <!-- Header -->
      <header class="mb-12">
        <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">
          {title}
        </h1>
        <p class="text-xl text-text-secondary">
          {subtitle}
        </p>
        {status && (
          <div class="mt-6 flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 rounded-md border border-border bg-bg-card px-3 py-1.5 text-xs text-text-muted">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              {status}
            </span>
          </div>
        )}
      </header>

      <!-- Markdown prose content -->
      <div class="project-prose text-lg text-text-secondary">
        <Content />
      </div>

      <!-- Stats grid -->
      {stats && stats.length > 0 && (
        <div class="mt-10">
          <h2 class="mb-4 text-xl font-semibold text-text">{statsTitle || "Numbers"}</h2>
          <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
            {stats.map((stat) => (
              <div class="rounded-lg border border-border bg-bg-card p-4">
                <div class="text-2xl font-bold text-text">{stat.value}</div>
                <div class="text-xs text-text-muted">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Technologies -->
      {technologies && technologies.length > 0 && (
        <div class="mt-10">
          <h2 class="mb-4 text-xl font-semibold text-text">Technologies</h2>
          <div class="flex flex-wrap gap-2">
            {technologies.map((tech) => (
              <span class="rounded-md border border-border bg-bg-card px-2.5 py-1 text-sm text-text-secondary">
                {tech}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</Layout>
